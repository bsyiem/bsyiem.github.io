---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { publications } from '../data/publications';

const highlights = publications.filter(p => p.featured);
---
<BaseLayout title="Brandon Syiem — HCI Researcher">
  <Hero />

  <!-- About -->
  <section class="max-w-6xl mx-auto px-8 lg:px-12 py-28">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-x-12 gap-y-16">

      <!-- Pull quote — spans most of the width -->
      <div class="lg:col-span-8">
        <blockquote class="font-display italic font-light text-[clamp(1.6rem,3.2vw,3rem)] leading-[1.25] text-ink">
          {/* "I believe that to effectively design technology for humans, I must first understand human design. My research is an unending endeavour to develop that understanding, and to test it through realised technologies." */}
          "To design technology for humans, I believe I must first understand human design. My research is an unending endeavour to do both."
        </blockquote>
      </div>

      <!-- Photo + position — right column -->
      <div class="lg:col-span-4 flex flex-col gap-6">
        <img
          src="/assets/images/brandon_nobg.png"
          alt="Brandon Syiem"
          class="w-40 h-40 object-cover object-top rounded-full border border-border"
          style="filter: drop-shadow(0 2px 12px rgba(0,0,0,0.08));"
        />
        <div class="space-y-1 text-sm">
          <p class="text-ink font-medium">Postdoctoral Research Fellow</p>
          <p class="text-muted">The University of Sydney</p>
        </div>
        <div class="space-y-1 text-xs text-muted">
          <p>PhD · The University of Melbourne, 2023</p>
          <p>PostDoc · Queensland University of Technology</p>
          <p>PostDoc · The University of Melbourne</p>
        </div>
      </div>

      <!-- Body copy — underneath pull quote -->
      <div class="lg:col-span-8 text-muted leading-relaxed space-y-4">
        <p>
          I am an HCI researcher fascinated by how human psychology, physiology, and behaviour can inform intelligent technological solutions. My research draws on those insights to investigate how eXtended Reality (XR) and Artificial Intelligence (AI) can be designed and implemented to enhance individual, social, and collaborative experiences.
        </p>
        <div class="flex flex-wrap gap-6 pt-2">
          <a href="https://scholar.google.com/citations?user=NLv_1gMAAAAJ&hl=en" target="_blank" class="link-accent text-sm">Google Scholar ↗</a>
          <a href="https://www.linkedin.com/in/brandon-victor-syiem-605455a8/" target="_blank" class="link-accent text-sm">LinkedIn ↗</a>
          <a href="https://www.researchgate.net/profile/Brandon-Syiem" target="_blank" class="link-accent text-sm">ResearchGate ↗</a>
        </div>
      </div>

    </div>
  </section>

  <!-- Section break -->
  <div class="border-t border-border mx-8 lg:mx-12"></div>

  <!-- Highlights -->
  <section class="max-w-6xl mx-auto px-8 lg:px-12 py-24">

    <div class="flex items-baseline justify-between mb-14">
      <h2 class="font-display font-light text-4xl">Highlights</h2>
      <a href="/publications"
        class="text-[0.65rem] tracking-widest uppercase text-muted hover:text-ink border-b border-border pb-px transition-colors">
        Full list ↗
      </a>
    </div>

    <div class="space-y-20">
      {highlights.map(pub => (
        <article class="border-b border-border pb-20 last:border-0 last:pb-0">

          <!-- Venue + award -->
          <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class={`text-[0.6rem] tracking-widest uppercase px-2 py-0.5 font-medium ${
              pub.venueType === 'journal'    ? 'tag-journal' :
              pub.venueType === 'conference' ? 'tag-conference' :
                                               'tag-workshop'
            }`}>
              {pub.venueShort}
            </span>
            {pub.award && (
              <span class="text-[0.6rem] tracking-widest uppercase text-amber-700 font-medium">
                🏆 {pub.award}
              </span>
            )}
          </div>

          <!-- Title -->
          <h3 class="font-display text-2xl sm:text-3xl font-light leading-snug text-ink mb-3">
            {pub.title}
          </h3>

          <!-- Authors -->
          <p class="text-muted text-sm mb-5" set:html={pub.authors.replace(
            /Brandon\s+(?:Victor\s+)?(?:V\.\s+)?Syiem/g,
            '<strong class="text-ink font-medium">$&</strong>'
          )} />

          <!-- Links -->
          <div class="flex flex-wrap gap-4 mb-8">
            {pub.doi && (
              <a href={pub.doi} target="_blank"
                class="text-[0.65rem] tracking-widest uppercase text-muted hover:text-ink border-b border-border pb-px transition-colors">
                {pub.venueShort} ↗
              </a>
            )}
            {pub.pdf && (
              <a href={pub.pdf} target="_blank"
                class="text-[0.65rem] tracking-widest uppercase text-muted hover:text-ink border-b border-border pb-px transition-colors">
                PDF ↗
              </a>
            )}
          </div>

          <!-- Video -->
          {pub.video && (
            <div class="mb-8 aspect-video bg-surface border border-border overflow-hidden">
              <iframe
                width="100%" height="100%"
                src={`https://www.youtube-nocookie.com/embed/${pub.video}`}
                title={pub.title}
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              />
            </div>
          )}

          <!-- Images (only if no video) -->
          {!pub.video && pub.images && pub.images.length > 0 && (
            <div class={`mb-8 gap-2 ${
              pub.images.length === 1 ? 'block' :
              pub.images.length === 2 ? 'grid grid-cols-2 items-stretch' :
                                        'grid grid-cols-3 items-stretch'
            }`}>
              {pub.images.map(src => (
                <div class="border border-border overflow-hidden h-full flex items-center justify-center bg-white">
                  <img src={src} alt={pub.title} class="w-full h-full object-contain" loading="lazy" />
                </div>
              ))}
            </div>
          )}

          <!-- Abstract -->
          {pub.abstract && (
            <p class="text-muted leading-relaxed text-sm">{pub.abstract}</p>
          )}

        </article>
      ))}
    </div>

  </section>
</BaseLayout>
