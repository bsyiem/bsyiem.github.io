---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { publications, allTopics, allYears, allVenueTypes } from '../../data/publications';

const venueTypeLabel: Record<string, string> = {
  journal:    'Journal',
  conference: 'Conference',
  workshop:   'Workshop / EA',
};
---
<BaseLayout title="Publications — Brandon Syiem">
  <div class="max-w-6xl mx-auto px-8 pt-32 pb-24">

    <header class="mb-8 border-b border-border pb-10">
      <p class="text-[0.7rem] tracking-widest2 uppercase text-muted mb-4">Research Output</p>
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4">
        <h1 class="font-display text-5xl sm:text-6xl font-light">Publications</h1>
      </div>
    </header>

    <!-- Filters -->
    <div id="filters" class="mb-10 flex flex-col gap-3">

      <!-- Row 1: Year (left) | Type (right) -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 items-stretch">

        <!-- Year column -->
        <div class="flex flex-col items-center">
          <span class="text-[0.72rem] tracking-widest2 uppercase text-muted self-start">Year</span>
          <div class="flex-1 flex items-center">
          <div class="flex flex-col gap-3">
            <div class="flex items-center gap-2">
              <span class="text-[0.6rem] uppercase tracking-widest text-muted w-4">Lo</span>
              <input id="year-lo" type="range" step="1" class="year-range w-56" />
              <span id="year-lo-label" class="text-[0.65rem] tabular-nums text-ink w-8"></span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-[0.6rem] uppercase tracking-widest text-muted w-4">Hi</span>
              <input id="year-hi" type="range" step="1" class="year-range w-56" />
              <span id="year-hi-label" class="text-[0.65rem] tabular-nums text-ink w-8"></span>
            </div>
          </div>
          </div>
        </div>

        <!-- Type column -->
        <div class="flex flex-col gap-2 items-center">
          <span class="text-[0.72rem] tracking-widest2 uppercase text-muted self-start">Type</span>
          <div class="flex items-center gap-5">

            <!-- Hub-and-spoke SVG (no labels, solid colours, 120° spacing) -->
            <!-- Hub: (30,50)  R=33
                 Journal    240° → (13.5, 21.4)
                 Conference   0° → (63,   50  )
                 Workshop   120° → (13.5, 78.6) -->
            <svg id="type-graph" viewBox="0 0 75 100" width="75" height="100"
                 class="select-none overflow-visible flex-shrink-0">
              <!-- Spokes -->
              <line id="spoke-journal"    x1="30" y1="50" x2="14" y2="21"
                    stroke="#b45309" stroke-width="1.5" opacity="0.3"/>
              <line id="spoke-conference" x1="30" y1="50" x2="63" y2="50"
                    stroke="#44403c" stroke-width="1.5" opacity="0.3"/>
              <line id="spoke-workshop"   x1="30" y1="50" x2="14" y2="79"
                    stroke="#be123c" stroke-width="1.5" opacity="0.3"/>
              <!-- Hub: All -->
              <g id="node-all" data-value="all" class="type-node" style="cursor:pointer">
                <circle cx="30" cy="50" r="10" fill="#111110"/>
              </g>
              <!-- Journal (amber) — 240° — square -->
              <g id="node-journal" data-value="journal" class="type-node" style="cursor:pointer">
                <rect x="7" y="14" width="14" height="14" fill="#b45309"/>
              </g>
              <!-- Conference (stone) — 0° — hexagon (flat-top, r=9) -->
              <g id="node-conference" data-value="conference" class="type-node" style="cursor:pointer">
                <polygon points="72,50 67.5,57.8 58.5,57.8 54,50 58.5,42.2 67.5,42.2" fill="#44403c"/>
              </g>
              <!-- Workshop (rose) — 120° — triangle, face normal aligned to spoke -->
              <!-- Spoke dir hub→node: (-16,29), normal toward hub: (16,-29) at -61.1°  -->
              <!-- Opposite vertex at 118.9°, other two at 238.9° and 358.9°, R=10      -->
              <g id="node-workshop" data-value="workshop" class="type-node" style="cursor:pointer">
                <polygon points="9,88 9,70 24,79" fill="#be123c"/>
              </g>
            </svg>

            <!-- Legend -->
            <div class="flex flex-col gap-2.5">
              <div class="legend-item flex items-center gap-2 cursor-pointer" data-type="journal">
                <span class="w-2.5 h-2.5 flex-shrink-0" style="background:#b45309"></span>
                <span class="text-[0.6rem] tracking-widest uppercase text-muted">Journal</span>
              </div>
              <div class="legend-item flex items-center gap-2 cursor-pointer" data-type="conference">
                <svg width="12" height="11" viewBox="0 0 12 11" class="flex-shrink-0">
                  <polygon points="11,5.5 8.5,9.8 3.5,9.8 1,5.5 3.5,1.2 8.5,1.2" fill="#44403c"/>
                </svg>
                <span class="text-[0.6rem] tracking-widest uppercase text-muted">Conference</span>
              </div>
              <div class="legend-item flex items-center gap-2 cursor-pointer" data-type="workshop">
                <svg width="12" height="11" viewBox="0 0 12 11" class="flex-shrink-0">
                  <polygon points="6,0 12,11 0,11" fill="#be123c"/>
                </svg>
                <span class="text-[0.6rem] tracking-widest uppercase text-muted">Workshop</span>
              </div>
            </div>

          </div>
        </div>

      </div>

      <!-- Row 2: Topic (full width) -->
      <div class="flex flex-col gap-2">
        <span class="text-[0.72rem] tracking-widest2 uppercase text-muted">Topic</span>
        <div class="flex items-center gap-2 flex-wrap">
          <button class="filter-btn is-active" data-filter="topic" data-value="all">All</button>
          {allTopics.map(t => (
            <button class="filter-btn" data-filter="topic" data-value={t}>{t}</button>
          ))}
        </div>
      </div>

    </div>

    <!-- List -->
    <div class="divide-y divide-border" id="pub-list">
      {publications.map((pub) => (
        <div
          class="pub-card py-7 grid grid-cols-12 gap-4 group"
          data-year={pub.year}
          data-type={pub.venueType}
          data-topics={pub.topics.join(',')}
        >
          <!-- Main -->
          <div class="col-span-12 sm:col-span-10">
            <div class="flex flex-wrap items-center gap-2 mb-2">
              <span class={`text-[0.6rem] tracking-widest uppercase px-2 py-0.5 font-medium ${
                pub.venueType === 'journal'    ? 'tag-journal' :
                pub.venueType === 'conference' ? 'tag-conference' :
                                                 'tag-workshop'
              }`}>
                {pub.venueShort}
              </span>
              {pub.award && (
                <span class="text-[0.6rem] tracking-widest uppercase text-amber-700">🏆 {pub.award}</span>
              )}
            </div>
            <p class="text-ink font-medium leading-snug mb-1 group-hover:text-accent transition-colors duration-200">
              {pub.title}
            </p>
            <p class="text-muted text-sm mb-3" set:html={pub.authors.replace(
              /Brandon\s+(?:Victor\s+)?(?:V\.\s+)?Syiem/g,
              '<strong class="text-ink font-medium">$&</strong>'
            )} />
            <div class="flex flex-wrap gap-1.5">
              {pub.topics.map(t => (
                <span class="text-[0.6rem] tracking-wide text-muted border border-border px-2 py-0.5">{t}</span>
              ))}
            </div>
          </div>

          <!-- Links -->
          <div class="col-span-12 sm:col-span-2 flex sm:flex-col gap-3 sm:items-end">
            {pub.doi && (
              <a href={pub.doi} target="_blank"
                class="text-[0.65rem] tracking-widest uppercase text-muted hover:text-ink transition-colors border-b border-border pb-px">
                DOI
              </a>
            )}
            {pub.pdf && (
              <a href={pub.pdf} target="_blank"
                class="text-[0.65rem] tracking-widest uppercase text-muted hover:text-ink transition-colors border-b border-border pb-px">
                PDF
              </a>
            )}
            {pub.video && (
              <a href={`https://www.youtube.com/watch?v=${pub.video}`} target="_blank"
                class="text-[0.65rem] tracking-widest uppercase text-muted hover:text-ink transition-colors border-b border-border pb-px">
                Video
              </a>
            )}
          </div>
        </div>
      ))}
    </div>

  </div>
</BaseLayout>

<style>
  .filter-btn {
    @apply text-[0.65rem] tracking-widest uppercase px-2.5 py-1 border border-border
           text-muted hover:text-ink hover:border-ink/30 transition-colors cursor-pointer;
  }
  .filter-btn.is-active {
    @apply bg-ink text-bg border-ink;
  }

  .year-range {
    -webkit-appearance: none;
    appearance: none;
    height: 1px;
    background: #d4d4d0;
    outline: none;
    cursor: pointer;
  }
  .year-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 12px; height: 12px;
    border-radius: 50%;
    background: #111110;
    cursor: pointer;
  }
  .year-range::-moz-range-thumb {
    width: 12px; height: 12px;
    border-radius: 50%;
    background: #111110;
    border: none;
    cursor: pointer;
  }
</style>

<script define:vars={{ allYears }}>
  const years = [...allYears].reverse(); // ascending: oldest first
  const N = years.length - 1;

  const loEl      = document.getElementById('year-lo');
  const hiEl      = document.getElementById('year-hi');
  const loLabel   = document.getElementById('year-lo-label');
  const hiLabel   = document.getElementById('year-hi-label');

  // Initialise
  loEl.min = hiEl.min = '0';
  loEl.max = hiEl.max = String(N);
  loEl.value = '0';
  hiEl.value = String(N);
  loLabel.textContent = years[0];
  hiLabel.textContent = years[N];

  loEl.addEventListener('input', () => {
    if (parseInt(loEl.value) > parseInt(hiEl.value)) loEl.value = hiEl.value;
    loLabel.textContent = years[parseInt(loEl.value)];
    apply();
  });

  hiEl.addEventListener('input', () => {
    if (parseInt(hiEl.value) < parseInt(loEl.value)) hiEl.value = loEl.value;
    hiLabel.textContent = years[parseInt(hiEl.value)];
    apply();
  });

  // ── Type graph ─────────────────────────────────────────────────
  const typeColors = {
    journal:    '#b45309',
    conference: '#44403c',
    workshop:   '#be123c',
  };

  const state = { type: 'all', topic: 'all' };

  function setTypeActive(value) {
    state.type = value;

    // Hub dims when a specific type is selected
    const hub = document.querySelector('#node-all circle');
    hub.setAttribute('fill', value === 'all' ? '#111110' : '#999');

    // Outer nodes + spokes
    ['journal','conference','workshop'].forEach(t => {
      const g     = document.getElementById(`node-${t}`);
      const spoke = document.getElementById(`spoke-${t}`);
      const active = value === 'all' || value === t;
      g.style.opacity     = active ? '1' : '0.2';
      spoke.setAttribute('opacity', value === t ? '0.9' : value === 'all' ? '0.3' : '0.08');
    });

    // Legend
    document.querySelectorAll('.legend-item').forEach(item => {
      const active = value === 'all' || item.dataset.type === value;
      item.style.opacity = active ? '1' : '0.3';
    });

    apply();
  }

  document.querySelectorAll('.type-node').forEach(node => {
    node.addEventListener('click', () => setTypeActive(node.dataset.value));
  });

  document.querySelectorAll('.legend-item').forEach(item => {
    item.addEventListener('click', () => {
      const t = item.dataset.type;
      setTypeActive(state.type === t ? 'all' : t);
    });
  });

  // ── Topic filter ────────────────────────────────────────────────
  function apply() {
    const lo = years[parseInt(loEl.value)];
    const hi = years[parseInt(hiEl.value)];
    const cards = document.querySelectorAll('.pub-card');
    cards.forEach(c => {
      const y = parseInt(c.dataset.year);
      const ok =
        y >= lo && y <= hi &&
        (state.type  === 'all' || c.dataset.type  === state.type) &&
        (state.topic === 'all' || (c.dataset.topics ?? '').split(',').includes(state.topic));
      c.style.display = ok ? '' : 'none';
    });
  }

  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const f = btn.dataset.filter;
      state[f] = btn.dataset.value ?? 'all';
      document.querySelectorAll(`.filter-btn[data-filter="${f}"]`)
        .forEach(b => b.classList.toggle('is-active', b === btn));
      apply();
    });
  });
</script>
