---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { publications } from '../../data/publications';

const highlights = publications.filter(p => p.featured);
---
<BaseLayout title="Publication Highlights — Brandon Syiem">
  <div class="max-w-4xl mx-auto px-8 pt-32 pb-24">

    <header class="mb-14 border-b border-border pb-10">
      <p class="text-[0.7rem] tracking-widest2 uppercase text-muted mb-4">Select Works</p>
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4">
        <h1 class="font-display text-5xl sm:text-6xl font-light">Highlights</h1>
        <a href="/publications"
          class="text-[0.7rem] tracking-widest uppercase text-muted hover:text-ink transition-colors border-b border-border pb-px self-start sm:self-auto">
          All Publications ↗
        </a>
      </div>
    </header>

    <div class="space-y-20">
      {highlights.map(pub => (
        <article class="border-b border-border pb-20 last:border-0 last:pb-0">

          <!-- Venue + award -->
          <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class={`text-[0.6rem] tracking-widest uppercase px-2 py-0.5 font-medium ${
              pub.venueType === 'journal'    ? 'tag-journal' :
              pub.venueType === 'conference' ? 'tag-conference' :
                                               'tag-workshop'
            }`}>
              {pub.venueShort}
            </span>
            {pub.award && (
              <span class="text-[0.6rem] tracking-widest uppercase text-amber-700 font-medium">
                🏆 {pub.award}
              </span>
            )}
          </div>

          <!-- Title -->
          <h2 class="font-display text-2xl sm:text-3xl font-light leading-snug text-ink mb-3">
            {pub.title}
          </h2>

          <!-- Authors -->
          <p class="text-muted text-sm mb-5" set:html={pub.authors.replace(
            /Brandon\s+(?:Victor\s+)?(?:V\.\s+)?Syiem/g,
            '<strong class="text-ink font-medium">$&</strong>'
          )} />

          <!-- Links -->
          <div class="flex flex-wrap gap-4 mb-8">
            {pub.doi && (
              <a href={pub.doi} target="_blank"
                class="text-[0.65rem] tracking-widest uppercase text-muted hover:text-ink border-b border-border pb-px transition-colors">
                {pub.venueShort} ↗
              </a>
            )}
            {pub.pdf && (
              <a href={pub.pdf} target="_blank"
                class="text-[0.65rem] tracking-widest uppercase text-muted hover:text-ink border-b border-border pb-px transition-colors">
                PDF ↗
              </a>
            )}
          </div>

          <!-- Video -->
          {pub.video && (
            <div class="mb-8 aspect-video bg-surface border border-border overflow-hidden">
              <iframe
                width="100%" height="100%"
                src={`https://www.youtube-nocookie.com/embed/${pub.video}`}
                title={pub.title}
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              />
            </div>
          )}

          <!-- Images (only if no video) -->
          {!pub.video && pub.images && pub.images.length > 0 && (
            <div class={`mb-8 gap-2 ${
              pub.images.length === 1 ? 'block' :
              pub.images.length === 2 ? 'grid grid-cols-2 items-stretch' :
                                        'grid grid-cols-3 items-stretch'
            }`}>
              {pub.images.map(src => (
                <div class="border border-border overflow-hidden h-full flex items-center justify-center bg-white">
                  <img src={src} alt={pub.title} class="w-full h-full object-contain" loading="lazy" />
                </div>
              ))}
            </div>
          )}

          <!-- Abstract -->
          {pub.abstract && (
            <p class="text-muted leading-relaxed text-sm">{pub.abstract}</p>
          )}

        </article>
      ))}
    </div>
  </div>
</BaseLayout>
